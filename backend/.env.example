# ─────────────────────────────────────────────
#  VedaAI Backend — Environment Variables
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS + Socket.io)
FRONTEND_URL=http://localhost:3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# Redis (optional — app works without it, but BullMQ queue is disabled)
# For local: redis://localhost:6379
# For Redis Cloud / Render Redis: rediss://:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
